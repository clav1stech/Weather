__pycache__/
*.pyc

# Fichiers temporaires Excel (verrous OneDrive / Excel)
~$*.xlsx

# Sauvegardes locales — jamais synchronisées sur GitHub
Export/

# Métadonnées OS
.DS_Store
Thumbs.db

# Réglages Claude Code personnels (non partagés)
.claude/settings.local.json

# Secrets locaux (clé API Météo-France…) — JAMAIS versionnés. En CI, la clé
# vit dans un secret GitHub Actions (METEOFRANCE_API_KEY), jamais dans le code.
.env
.env.*

# Environnement virtuel local (macOS)
.venv/

# Références de non-régression (dépendent de la base locale au moment de la
# capture — se régénèrent via tools/*.py capture, cf. docs/CODEMAP.md)
tools/golden/

# Sauvegardes locales du parquet (copies datées avant import legacy) — restent
# sur le poste (+ OneDrive), jamais poussées : le workflow ne committe que
# data/*.parquet de premier niveau, ce dossier n'y entre pas.
data/backups/
